  "components": {
    "schemas": {
      "AdoptionRecord": {
        "required": [
          "id",
          "pet"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "pet": {
            "$ref": "#/components/schemas/Animal"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Animal": {
        "required": [
          "kind"
        ],
        "type": "object",
        "anyOf": [
          {
            "$ref": "#/components/schemas/AnimalCatPet"
          },
          {
            "$ref": "#/components/schemas/AnimalDogPet"
          }
        ],
        "discriminator": {
          "propertyName": "kind",
          "mapping": {
            "cat": "#/components/schemas/AnimalCatPet",
            "dog": "#/components/schemas/AnimalDogPet"
          }
        }
      },
      "AnimalCatPet": {
        "required": [
          "name"
        ],
        "properties": {
          "kind": {
            "enum": [
              "cat"
            ],
            "type": "string"
          },
          "livesLeft": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "AnimalDogPet": {
        "required": [
          "name"
        ],
        "properties": {
          "kind": {
            "enum": [
              "dog"
            ],
            "type": "string"
          },
          "goodBoy": {
            "type": "boolean"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "CreateAdoptionRequest": {
        "required": [
          "pet"
        ],
        "type": "object",
        "properties": {
          "pet": {
            "$ref": "#/components/schemas/Animal"
          },
          "notes": {
            "type": [
              "null",
              "string"
            ]
          },
          "labels": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          }
        }
      },
      "DashboardResponse": {
        "required": [
          "owner",
          "tags",
          "metrics",
          "primaryPet"
        ],
        "type": "object",
        "properties": {
          "owner": {
            "$ref": "#/components/schemas/UserSummary"
          },
          "state": {
            "$ref": "#/components/schemas/ProjectState"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metrics": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/Metric"
            }
          },
          "primaryPet": {
            "$ref": "#/components/schemas/Animal"
          },
          "backupPet": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Animal"
              }
            ]
          }
        }
      },
      "EntityTagHeaderValue": {
        "type": "object",
        "properties": {
          "tag": {
            "$ref": "#/components/schemas/StringSegment"
          },
          "isWeak": {
            "type": "boolean"
          }
        }
      },
      "FileContentResult": {
        "type": "object",
        "properties": {
          "fileContents": {
            "type": "string",
            "format": "byte"
          },
          "contentType": {
            "type": [
              "null",
              "string"
            ]
          },
          "fileDownloadName": {
            "type": [
              "null",
              "string"
            ]
          },
          "lastModified": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "entityTag": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/EntityTagHeaderValue"
              }
            ]
          },
          "enableRangeProcessing": {
            "type": "boolean"
          }
        }
      },
      "HelloRequest": {
        "required": [
          "firstName"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "HelloResponse": {
        "required": [
          "message"
        ],
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "IFormFile": {
        "type": "string",
        "format": "binary"
      },
      "Metric": {
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "format": "double"
          },
          "unit": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "PatchUser": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": [
              "null",
              "string"
            ]
          },
          "lastName": {
            "type": [
              "null",
              "string"
            ]
          },
          "nickname": {
            "type": [
              "null",
              "string"
            ]
          },
          "labels": {
            "type": [
              "null",
              "object"
            ],
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ProjectState": {
        "enum": [
          "Draft",
          "Active",
          "Archived"
        ]
      },
      "StringSegment": {
        "type": "object",
        "properties": {
          "buffer": {
            "type": [
              "null",
              "string"
            ]
          },
          "offset": {
            "type": "integer",
            "format": "int32"
          },
          "length": {
            "type": "integer",
            "format": "int32"
          },
          "value": {
            "type": [
              "null",
              "string"
            ]
          },
          "hasValue": {
            "type": "boolean"
          }
        }
      },
      "UploadAssetResponse": {
        "required": [
          "id",
          "fileName"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "fileName": {
            "type": "string"
          },
          "metadata": {
            "type": [
              "null",
              "object"
            ],
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "UserSummary": {
        "required": [
          "id",
          "firstName",
          "lastName"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "nickname": {
            "type": [
              "null",
              "string"
            ]
          },
          "state": {
            "$ref": "#/components/schemas/ProjectState"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "nextReviewOn": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "labels": {
            "type": [
              "null",
              "object"
            ],
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "description": "JWT Bearer authentication",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "tags": [
    {
      "name": "Catalog"
    },
    {
      "name": "Diagnostics"
    },
    {
      "name": "Files"
    },
    {
      "name": "User"
    }
  ]
}